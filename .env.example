# personal-blog environment. The engine reads all of these via process.env
# (see presidocs/.env.example for the full annotated list). Bun auto-loads .env.

# Required for OAuth login / comments. Generate: openssl rand -base64 48
SESSION_SECRET=

# Non-localhost deploys: the base URL OAuth redirect URIs are built from.
# OAUTH_REDIRECT_BASE=https://blog.example.com

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=

# Author moderation list (comma-separated <provider>:<sub>). Usually empty.
BLOCKED_USERS=

# --- MOSS-TTS (production voice; only for `bun run generate:prod`) -----------
# Per-machine paths; not needed for the default `say` iteration voice.
# MOSS_TTS_DIR=/path/to/MOSS-TTS
# MOSS_TTS_VOICE=/path/to/my_voice.wav
