{
  "name": "personal-blog",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun engine/generate/post-routes.ts && bun --hot index.ts",
    "start": "bun engine/generate/post-routes.ts && bun index.ts",
    "generate": "bun engine/generate/generate.ts",
    "generate:prod": "bun engine/generate/generate.ts --tts=moss",
    "sound-test": "bun engine/generate/sound-test.ts posts/common-terms.pls --tts=moss --all",
    "clean": "bun engine/generate/clean.ts",
    "build": "bun engine/generate/post-meta.ts && bun engine/generate/post-versions.ts && bun build ./index.html ./posts/*.html --outdir ./dist --target browser && bun engine/generate/copy-static.ts && bun engine/generate/share-card.ts && bun engine/generate/strip-served-html.ts && bun engine/generate/feeds.ts",
    "deploy": "bun run build && wrangler deploy",
    "resolve-threads": "bun engine/authoring/resolveThreads.ts",
    "export-annotations": "bun engine/authoring/exportAnnotations.ts",
    "list-unresolved": "bun engine/authoring/listUnresolved.ts",
    "pull-comments": "bun engine/authoring/r2Sync.ts pull",
    "push-resolutions": "bun engine/authoring/r2Sync.ts push"
  },
  "dependencies": {
    "presidocs": "link:presidocs",
    "gsap": "^3.15.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "@types/bun": "latest",
    "wrangler": "^4.90.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
