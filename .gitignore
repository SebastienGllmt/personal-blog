# dependencies
node_modules

# output
dist
generated

# per-build generated maps + dev route table (regenerated by build / dev)
.generated

# dotenv
.env
.env.local

# Wrangler dev secrets (counterpart of .env for the `dev:edge` loop —
# keep `.dev.vars.example` committed, the real `.dev.vars` carries secrets).
.dev.vars

# Cloudflare wrangler working directory (also persists local Miniflare R2
# state for the dev server's Miniflare-backed COMMENTS binding).
.wrangler

# Finder (macOS)
.DS_Store

# local analysis tooling (e.g. the DuckDB CLI binary under research/)
/tools/

# avoid leaking author information like reference voice clip
authors/

# heavy / regenerable research data artifacts. Canonical home is generated/
# (already ignored). Committed analysis data is .csv, intentionally NOT ignored.
*.jsonl
*.parquet
*.duckdb
*.duckdb.wal
*.duckdb.tmp
